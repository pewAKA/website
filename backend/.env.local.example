# 此文件由 scripts/start-local-remote-db.ps1 读取；复制为 .env.local 后填写真实值。
DB_URL=jdbc:mysql://127.0.0.1:3307/personal_website?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USERNAME=website_app
DB_PASSWORD=replace-with-the-server-database-password
APP_JWT_SECRET=replace-with-a-local-base64-jwt-secret
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=8081
